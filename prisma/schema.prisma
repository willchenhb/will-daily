generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model DiaryEntry {
  id        Int      @id @default(autoincrement())
  date      String   @unique // YYYY-MM-DD
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WeeklyPlan {
  id        Int        @id @default(autoincrement())
  weekStart String     @unique // YYYY-MM-DD (Monday)
  title     String?
  content   String?    // Weekly reflection HTML
  todos     TodoItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model TodoItem {
  id           Int        @id @default(autoincrement())
  weeklyPlanId Int
  weeklyPlan   WeeklyPlan @relation(fields: [weeklyPlanId], references: [id], onDelete: Cascade)
  text         String
  completed    Boolean    @default(false)
  note         String?    // Feedback/notes on completion
  order        Int
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([weeklyPlanId])
}

model Note {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  category  String?  // Lowercase, trimmed
  summary   String?  // AI-generated
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

model CuratedArticle {
  id        Int      @id @default(autoincrement())
  url       String   @unique
  title     String
  author    String?
  image     String?
  content   String?
  summary   String?
  keyPoints String?  // JSON array of strings
  tags      String?  // Comma-separated
  category  String?  // tech|finance|health|education|lifestyle|business|other
  source    String?
  status    String   @default("done") // pending|analyzing|done|failed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
  @@index([category])
  @@index([status])
}

model Setting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}
