generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model DiaryEntry {
  id        Int      @id @default(autoincrement())
  date      String   @unique // YYYY-MM-DD
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WeeklyPlan {
  id        Int        @id @default(autoincrement())
  weekStart String     @unique // YYYY-MM-DD (Monday)
  title     String?
  content   String?    // Weekly reflection HTML
  todos     TodoItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model TodoItem {
  id           Int        @id @default(autoincrement())
  weeklyPlanId Int
  weeklyPlan   WeeklyPlan @relation(fields: [weeklyPlanId], references: [id], onDelete: Cascade)
  text         String
  completed    Boolean    @default(false)
  note         String?    // Feedback/notes on completion
  order        Int
  milestoneId  Int?
  milestone    Milestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([weeklyPlanId])
  @@index([milestoneId])
}

model Note {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  category  String?  // Lowercase, trimmed
  summary   String?  // AI-generated
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

model CuratedArticle {
  id        Int      @id @default(autoincrement())
  url       String   @unique
  title     String
  author    String?
  image     String?
  content   String?
  summary   String?
  keyPoints String?  // JSON array of strings
  tags      String?  // Comma-separated
  category  String?  // tech|finance|health|education|lifestyle|business|other
  source    String?
  status    String   @default("done") // pending|analyzing|done|failed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
  @@index([category])
  @@index([status])
}

model Setting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String   // bcrypt hash
  role      String   @default("user") // "admin" | "user"
  apiToken  String   @unique @default(uuid())
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TeamMember {
  id          Int      @id @default(autoincrement())
  name        String
  department  String?
  role        String?
  avatarColor String   @default("#3B82F6")
  level       Int      @default(1) // 0=负责人, 1=一级, 2=二级
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ownedProjects Project[]     @relation("ProjectOwner")
  ownedRisks    ProjectRisk[] @relation("RiskOwner")
}

model Project {
  id             Int      @id @default(autoincrement())
  name           String
  code           String   @unique // e.g. "PRJ-001"
  description    String?
  category       String   // 产品交付|商业化|平台建设|技术攻关|组织管理
  status         String   @default("planning") // planning|active|paused|completed|cancelled
  priority       String   @default("P1") // P0|P1|P2|P3
  ownerId        Int
  owner          TeamMember @relation("ProjectOwner", fields: [ownerId], references: [id])
  startDate      String?  // YYYY-MM-DD
  targetEndDate  String?  // YYYY-MM-DD
  okrObjectiveId String?  // e.g. "CHB-O1"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  milestones Milestone[]
  risks      ProjectRisk[]

  @@index([ownerId])
  @@index([status])
  @@index([category])
}

model Milestone {
  id            Int      @id @default(autoincrement())
  projectId     Int
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title         String
  dueDate       String?  // YYYY-MM-DD
  completedDate String?  // YYYY-MM-DD
  status        String   @default("not_started") // not_started|in_progress|completed|delayed
  deliverables  String?
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  todos TodoItem[]

  @@index([projectId])
}

model ProjectRisk {
  id             Int         @id @default(autoincrement())
  projectId      Int
  project        Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title          String
  probability    String      @default("medium") // low|medium|high
  impact         String      @default("medium") // low|medium|high
  mitigation     String?
  status         String      @default("open") // open|mitigated|closed
  ownerId        Int?
  owner          TeamMember? @relation("RiskOwner", fields: [ownerId], references: [id])
  identifiedDate String?     // YYYY-MM-DD
  resolvedDate   String?     // YYYY-MM-DD
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([projectId])
  @@index([ownerId])
}

model DailyDigest {
  id        Int      @id @default(autoincrement())
  date      String   // YYYY-MM-DD
  category  String   // 时政新闻|AI新闻|产品热点
  title     String
  summary   String?
  url       String?
  source    String?  // e.g. "openclaw"
  createdAt DateTime @default(now())

  @@index([date])
  @@index([category])
}

model ContentNode {
  id         Int      @id @default(autoincrement())
  sourceType String   // 'diary' | 'weekly' | 'note' | 'article'
  sourceId   Int
  title      String
  snippet    String
  embedding  String?  // JSON: keyword weights object
  method     String   @default("kimi")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  edgesA     ContentEdge[] @relation("edgesFromA")
  edgesB     ContentEdge[] @relation("edgesFromB")

  @@unique([sourceType, sourceId])
  @@index([sourceType])
}

model ContentEdge {
  id       Int         @id @default(autoincrement())
  nodeAId  Int
  nodeBId  Int
  nodeA    ContentNode @relation("edgesFromA", fields: [nodeAId], references: [id], onDelete: Cascade)
  nodeB    ContentNode @relation("edgesFromB", fields: [nodeBId], references: [id], onDelete: Cascade)
  weight   Float

  @@unique([nodeAId, nodeBId])
  @@index([nodeAId])
  @@index([nodeBId])
}
